# OpenAI 兼容聊天 API（三项都填才能聊天；可在启动向导或托盘「设置…」填写）
# 旧版 DEEPSEEK_* 仍可读，保存后会迁移为 CHAT_API_*
CHAT_API_KEY=
CHAT_API_BASE_URL=
CHAT_API_MODEL=

USER_NAME=

SHOW_SPLASH=1
SPLASH_MS=1200
SHOW_CHARACTER_PICKER=1

APP_ICON_SOURCE=形象/银杰动漫形象/歪头.png
APP_ICON_BORDER_COLOR=#C9A227
APP_ICON_BG_TINT=#FFF8F0

# 形象包：形象/<文件夹名>/ 启动时自动扫描；SIG 由程序维护，用于文件夹改名后自动匹配
CHARACTER_PACK=PuppyPal线条小狗
# CHARACTER_PACK_SIG=
CHARACTER_MAX_HEIGHT=220
MOOD_SWITCH_MS=4500
CHARACTER_MATTE=safe
CHARACTER_USE_GIF=auto
CHARACTER_PERSONA=auto

# 运行模式：survival=生存（12 段 HP、喂食、饿死变骷髅）| normal=普通（无 HP）
PET_MODE=survival
# 生存记忆：1=退出程序也按真实时间扣 HP（可离线饿死）| 0=仅运行时扣 HP
SURVIVAL_MEMORY_MODE=0

# 生存模式参数（普通模式可忽略）
# VITALITY_HP_START=6
# VITALITY_FEED_HOURS=1
# VITALITY_HP_SEGMENTS=12
# VITALITY_COLOR_RED=#DC4641
# VITALITY_COLOR_YELLOW=#E6BE37
# VITALITY_COLOR_GREEN=#5ABE55
